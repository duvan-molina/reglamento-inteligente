rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getRole(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getRole(request.auth.uid) == 'admin';
    }

    // --- Collections ---

    // 1. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.size() == 4 
          && data.uid == request.auth.uid 
          && data.email is string 
          && data.role in ['admin', 'user']
          && data.createdAt is timestamp;
      }

      allow get: if isSignedIn(); // Allow reading profile to check roles
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['email']) 
                    || (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['role']));
    }

    // 2. Documents Collection
    match /documents/{docId} {
      function isValidDocument(data) {
        return data.size() >= 5
          && data.name is string && data.name.size() <= 255
          && data.storagePath is string
          && data.uploadedBy == request.auth.uid
          && data.createdAt == request.time;
      }

      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidDocument(incoming());
      allow update: if isAdmin() && isValidDocument(incoming());
      allow delete: if isAdmin();
    }

    // 3. Queries Collection
    match /queries/{queryId} {
      function isValidQuery(data) {
        return data.size() >= 4
          && data.userId == request.auth.uid
          && data.question is string && data.question.size() <= 1000
          && data.createdAt == request.time;
      }

      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidQuery(incoming());
    }
  }
}
